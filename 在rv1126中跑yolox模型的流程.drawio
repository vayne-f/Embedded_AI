        </mxCell>
        <mxCell id="IWO89DZMRxDcJP3v9Gk--4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="从RK官方获取到SDK开发包，并拷贝到Ubuntu开发环境下" vertex="1">
          <mxGeometry height="60" width="120" x="77.5" y="175" as="geometry" />
        </mxCell>
